# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8001

# Database
DATABASE_URL=postgresql+asyncpg://news_user:news_password@postgres/news_db

# AI Settings (OpenAI-compatible API)
AI_API_KEY=your-api-key-here
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4-turbo-preview

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHANNEL_ID=@your-channel

# Logo Settings
LOGO_PATH=/app/static/images/logo.png
LOGO_POSITION=bottom-right
LOGO_OPACITY=0.7

# Parser Settings
PARSER_INTERVAL=300  # seconds between parser runs
MAX_POSTS_PER_RUN=10

# Storage
UPLOAD_FOLDER=/app/static/uploads
IMAGES_FOLDER=/app/static/images

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
