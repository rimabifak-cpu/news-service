# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8001

# Database
DATABASE_URL=postgresql+asyncpg://news_user:news_password@postgres/news_db

# AI Settings (OpenRouter - совместим с OpenAI API)
AI_API_KEY=sk-or-v1-...
AI_API_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-3.5-turbo

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHANNEL_ID=@your-channel

# Logo Settings
LOGO_PATH=/app/static/images/logo.png
LOGO_POSITION=bottom-right
LOGO_OPACITY=0.7

# Parser Settings
PARSER_INTERVAL=60  # 1 минута
MAX_POSTS_PER_RUN=10

# Storage
UPLOAD_FOLDER=/app/static/uploads
IMAGES_FOLDER=/app/static/images

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
