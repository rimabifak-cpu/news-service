# ============================================
#   News Service - Полный файл настроек
# ============================================

# Приложение
APP_HOST=0.0.0.0
APP_PORT=8001

# База данных (не менять)
DATABASE_URL=postgresql+asyncpg://news_user:news_password@postgres/news_db

# ============================================
#   AI НАСТРОЙКИ (обязательно заполнить)
# ============================================

# Получите API ключ: https://platform.openai.com/api-keys
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API URL (OpenAI или совместимый)
AI_API_URL=https://api.openai.com/v1

# Модель AI
AI_MODEL=gpt-4-turbo-preview

# ============================================
#   TELEGRAM НАСТРОЙКИ (обязательно заполнить)
# ============================================

# Создайте бота у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ID канала для публикации (начинается с @ или -100...)
TELEGRAM_CHANNEL_ID=@your-channel-name

# ============================================
#   ЛОГОТИП (опционально)
# ============================================

# Путь к логотипу в контейнере
LOGO_PATH=/app/static/images/logo.svg

# Позиция: top-left, top-right, bottom-left, bottom-right
LOGO_POSITION=bottom-right

# Прозрачность: 0.0 - 1.0
LOGO_OPACITY=0.7

# ============================================
#   ПАРСЕР (опционально)
# ============================================

# Интервал автопарсинга в секундах (300 = 5 минут)
PARSER_INTERVAL=300

# Максимум постов за один запуск
MAX_POSTS_PER_RUN=10

# ============================================
#   ХРАНИЛИЩЕ (не менять)
# ============================================

UPLOAD_FOLDER=/app/static/uploads
IMAGES_FOLDER=/app/static/images

# ============================================
#   АДМИН ПАНЕЛЬ (опционально)
# ============================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
